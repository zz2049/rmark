{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RMark",
  "version": "0.1.0",
  "identifier": "dev.rmark.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RMark",
        "width": 1080,
        "height": 760,
        "minWidth": 620,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:"
    }
  },
  "bundle": {
    "active": false,
    "icon": [],
    "targets": "all"
  }
}
